generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://neondb_owner:npg_uNKHL4Wyhb6E@ep-wild-breeze-amog6v39-pooler.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require"
}

model Student {
  universityId      String   @id
  name              String
  password          String
  email             String?  @unique
  gpa               Float    @default(0.0)
  passedHours       Int      @default(0)
  department        String   @default("General")
  year              String   @default("First")
  registeredCourses String[]
  academicHistory   Json?    @default("[]")
}

model Course {
  code          String   @id
  name          String
 creditHours Int @default(3)
  level         Int
  prerequisites String   @default("")
  professor     String   @default("TBA")
  capacity      Int      @default(60)
  enrolled      Int      @default(0)
  status        String   @default("Available")
}

model Admin {
  username String   @id
  password String
  name     String
}

model AdminLog {
  id          Int      @id @default(autoincrement())
  studentId   String
  studentName String
  courseCode  String
  courseName  String
  timestamp   DateTime @default(now())
}
