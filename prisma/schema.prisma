generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  universityId      String   @id
  name              String
  password          String
  email             String?  @unique
  gpa               Float    @default(0.0)
  passedHours       Int      @default(0)
  department        String   @default("General")
  year              Int      @default(1)
  registeredCourses String[]
  academicHistory   Json?    @default("[]")
}

model Course {
  code          String   @id
  name          String
  credits       Int
  level         Int
  prerequisites String[]
  professor     String   @default("TBA")
  capacity      Int      @default(60)
  status        String   @default("Available")
}

model Admin {
  username String   @id
  password String
  name     String
}

model AdminLog {
  id          Int      @id @default(autoincrement())
  studentId   String
  studentName String
  courseCode  String
  courseName  String
  timestamp   DateTime @default(now())
}
